# Private strategy / discussion notes (not for public release)
private/

# super-harness workspace state — never commit to this repo (it's per-workspace
# user state; user projects that USE super-harness manage their own .harness/).
# Subagents running sanity checks may accidentally create one here.
.harness/
# Exception: the in-tree onboarding demo (examples/demo-openspec-claude/) ships
# a seeded .harness/ so visitors see what the post-init state looks like. Git
# requires re-including BOTH the directory and its contents — re-including only
# the directory still leaves children excluded by the parent rule above.
!examples/demo-openspec-claude/.harness/
!examples/demo-openspec-claude/.harness/**

# OS
.DS_Store

# Editor
.vscode/
.idea/

# Node (placeholder for future)
node_modules/
*.log

# Python build artifacts
dist/
build/
*.egg-info/

# Python virtual environments — glob so leftover review/test venvs
# (`.venv-review/`, `.venv-wheel/`, etc.) are also ignored. Smoke walk v4
# caught a sdist-build crash where hatchling included a stale `.venv-review/`
# whose `bin/python3.X` was an absolute symlink — Python 3.12+ tarfile
# refuses to extract absolute-link members. Defense in depth: the hatchling
# exclude block in `pyproject.toml [tool.hatch.build]` also excludes
# `.venv*/` so even if a venv is in-tree but un-gitignored, the sdist
# stays clean.
.venv*/

# Python caches
__pycache__/
.pytest_cache/
.mypy_cache/
.ruff_cache/
